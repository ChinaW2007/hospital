# ============================================================
# Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your actual values

# Database
DATABASE_URL=sqlite:///./app.db

# HIS MySQL Configuration
HIS_MYSQL_HOST=YOUR_MYSQL_HOST
HIS_MYSQL_PORT=3306
HIS_MYSQL_USER=YOUR_MYSQL_USER
HIS_MYSQL_PASS=YOUR_MYSQL_PASSWORD
HIS_MYSQL_DB=YOUR_DATABASE_NAME

# Camera Configuration
CAMERA_HOST=YOUR_CAMERA_IP
CAMERA_PORT=554
CAMERA_USER=admin
CAMERA_PASSWORD=YOUR_CAMERA_PASSWORD
CAMERA_AUDIO_PORT=80

# ROS WebSocket
ROS_WS_HOST=YOUR_ROS_IP
ROS_WS_PORT=9090
ROS_TOPIC=/car01_pub